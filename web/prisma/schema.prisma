// ThinkThru data model — translated from docs/DATA_MODEL.md.
// Postgres. UUID primary keys. Soft deletes (deletedAt) where the spec calls for them.
//
// v1 scope note: pgvector embeddings, attachments, and search-query logging from the
// spec are deferred to phase 2 and intentionally not modelled here yet.

generator client {
  provider        = "prisma-client-js"
  // driverAdapters lets us run on the Neon serverless driver (WebSocket proxy)
  // instead of a cold TCP+TLS connection — opt-in via NEON_SERVERLESS=1 (see db.ts).
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────
// Auth.js (NextAuth) adapter models
// ─────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────────────────────
// Core entities
// ─────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  name         String    @default("")
  image        String?   @map("avatar_url")
  bio          String?
  emailVerified DateTime? @map("email_verified")
  createdAt    DateTime  @default(now()) @map("created_at")
  lastActiveAt DateTime? @map("last_active_at")
  deletedAt    DateTime? @map("deleted_at")

  // Notification preferences + a one-click unsubscribe token for email footers.
  emailNotify  Boolean   @default(true) @map("email_notify")
  pushNotify   Boolean   @default(true) @map("push_notify")
  digestNotify Boolean   @default(true) @map("digest_notify")
  unsubToken   String?   @unique @map("unsub_token")

  accounts     Account[]
  sessions     Session[]
  pushSubscriptions PushSubscription[]

  orgMemberships    OrgMember[]
  gardenMemberships GardenMember[]
  seedMemberships   SeedMember[]
  createdGardens    Garden[]       @relation("GardenCreatedBy")
  seeds             Seed[]
  stageVotes        SeedStageVote[]
  contributions     Contribution[]
  reactions         ContributionReaction[]
  endorsementsGiven ContributionEndorsement[]
  bloomsTipped      Bloom[]        @relation("BloomCreatedBy")
  notifications     Notification[] @relation("NotificationRecipient")
  actedNotifications Notification[] @relation("NotificationActor")
  recognitionsReceived UserRecognition[] @relation("RecognitionUser")
  recognitionsAwarded  UserRecognition[] @relation("RecognitionAwardedBy")
  invitesSent          Invite[]          @relation("InvitesSent")
  stakeRatingsGiven    StakeRating[]     @relation("StakeRater")
  stakeRatingsReceived StakeRating[]     @relation("StakeRatee")
  pollsCreated         Poll[]
  pollVotes            PollVote[]
  quorumBallots        QuorumBallot[]    @relation("QuorumRater")
  quorumHardcodes      QuorumHardcode[]  @relation("QuorumHardcodedBy")
  seedFollows          SeedFollow[]
  seedReports          SeedReport[]
  interests            UserInterest[]

  @@map("users")
}

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  logoUrl   String?  @map("logo_url")
  plan      String   @default("free") // free | pro | enterprise
  ssoDomain String?  @map("sso_domain") // auto-join org when email domain matches
  createdAt DateTime @default(now()) @map("created_at")

  members OrgMember[]
  gardens Garden[]
  invites Invite[]

  @@map("organizations")
}

model OrgMember {
  orgId    String   @map("org_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  role     String   @default("member") // member | admin | owner
  joinedAt DateTime @default(now()) @map("joined_at")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([orgId, userId])
  @@map("org_members")
}

// ─────────────────────────────────────────────────────────────
// Gardens
// ─────────────────────────────────────────────────────────────

model Garden {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  module      String   @default("learning") // learning | achievement | help | mentorship | network | explore
  name        String
  slug        String
  description String?
  emoji       String   @default("🌱")
  stage       String   @default("germinating") // germinating | growing | thriving | dormant
  visibility  String   @default("public") // public (any org member) | private (garden members only)
  createdById String?  @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  org       Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy User?          @relation("GardenCreatedBy", fields: [createdById], references: [id])
  members   GardenMember[]
  seeds     Seed[]
  blooms    Bloom[]
  recognitions UserRecognition[]
  invites   Invite[]

  @@unique([orgId, slug])
  @@map("gardens")
}

model GardenMember {
  gardenId String   @map("garden_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  role     String   @default("member") // member | caretaker | steward
  joinedAt DateTime @default(now()) @map("joined_at")

  garden Garden @relation(fields: [gardenId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([gardenId, userId])
  @@map("garden_members")
}

// ─────────────────────────────────────────────────────────────
// Seeds
// ─────────────────────────────────────────────────────────────

model Seed {
  id          String    @id @default(uuid()) @db.Uuid
  gardenId    String    @map("garden_id") @db.Uuid
  createdById String    @map("created_by") @db.Uuid
  title       String
  content     String
  stage       String    @default("seed") // seed | germinating | sprouting | growing | bloomed
  visibility  String    @default("public") // public (anyone with garden access) | private (seed members only)
  // World-public: when true (and visibility=public), the seed is discoverable on
  // /explore by ANY signed-in user, across orgs — readable + followable; joining
  // to participate is open. lastActivityAt drives the Explore ranking.
  listed         Boolean   @default(false)
  lastActivityAt DateTime  @default(now()) @map("last_activity_at")
  bloomId     String?   @map("bloom_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  garden        Garden          @relation(fields: [gardenId], references: [id], onDelete: Cascade)
  createdBy     User            @relation(fields: [createdById], references: [id])
  stageVotes    SeedStageVote[]
  contributions Contribution[]
  blooms        Bloom[]
  members       SeedMember[]
  invites       Invite[]
  stakeRatings  StakeRating[]
  stakeState    SeedStake?
  stakeAdmissions StakeAdmission[]
  polls         Poll[]
  quorumBallots   QuorumBallot[]
  quorumHardcodes QuorumHardcode[]
  quorumState     QuorumState?
  followers     SeedFollow[]
  reports       SeedReport[]
  topics        SeedTopic[]

  @@index([gardenId, stage])
  @@index([listed, lastActivityAt])
  @@map("seeds")
}

// A user following a world-public seed from /explore — they get its activity
// (new contributions, blooms) through the normal notification pipeline.
model SeedFollow {
  seedId    String   @map("seed_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  // How loud: "all" (every reply), "highlights" (blooms/decisions/mentions
  // only), "muted" (nothing but @mentions). Auto-follow-on-view creates
  // "highlights"; contributing upgrades to "all".
  level     String   @default("all")
  createdAt DateTime @default(now()) @map("created_at")

  seed Seed @relation(fields: [seedId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([seedId, userId])
  @@index([userId])
  @@map("seed_follows")
}

// A report on public content (a seed or a contribution) for moderation. Keeps
// the public square safe: anyone can flag, owners/admins act on it.
model SeedReport {
  id             String   @id @default(uuid()) @db.Uuid
  seedId         String   @map("seed_id") @db.Uuid
  contributionId String?  @map("contribution_id") @db.Uuid
  reporterId     String   @map("reporter_id") @db.Uuid
  reason         String
  status         String   @default("open") // open | reviewed | dismissed
  createdAt      DateTime @default(now()) @map("created_at")

  seed     Seed @relation(fields: [seedId], references: [id], onDelete: Cascade)
  reporter User @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([seedId])
  @@map("seed_reports")
}

// A topic tag on a world-public seed (Phase 2 of Explore). Claude infers 1–3 at
// share time from a fixed taxonomy (see EXPLORE_TOPICS). Kept in its own table —
// not a column on seeds — so adding it never disturbs the heavily-queried seeds
// row shape (no migration-lag breakage on seed loads).
model SeedTopic {
  seedId String @map("seed_id") @db.Uuid
  topic  String // a free-form label Claude tagged, e.g. "Weekend Travel"

  seed Seed @relation(fields: [seedId], references: [id], onDelete: Cascade)

  @@id([seedId, topic])
  @@index([topic])
  @@map("seed_topics")
}

// DEPRECATED: the old fixed-taxonomy "interests" a person picked by hand. Explore
// personalisation now derives from a person's Claude-inferred profile topics
// (UserTopic), so nothing writes here anymore. Table kept to avoid a destructive
// migration; safe to drop later.
model UserInterest {
  userId String @map("user_id") @db.Uuid
  topic  String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, topic])
  @@index([topic])
  @@map("user_interests")
}

// Membership for PRIVATE seeds: the explicit set of people who can see and
// participate in a private seed (creator + invited). Public seeds don't use
// this — anyone with garden access can join them.
model SeedMember {
  seedId   String   @map("seed_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  role     String   @default("member") // member | steward
  joinedAt DateTime @default(now()) @map("joined_at")

  seed Seed @relation(fields: [seedId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([seedId, userId])
  @@map("seed_members")
}

model SeedStageVote {
  seedId  String   @map("seed_id") @db.Uuid
  userId  String   @map("user_id") @db.Uuid
  stage   String // seed | germinating | sprouting | growing | bloomed
  votedAt DateTime @default(now()) @map("voted_at")

  seed Seed @relation(fields: [seedId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([seedId, userId])
  @@index([seedId])
  @@map("seed_stage_votes")
}

// ─────────────────────────────────────────────────────────────
// Stake-weighted quorum
// ─────────────────────────────────────────────────────────────

// One rater's read of one person's stake in a seed. scores is a JSON map of
// stake-dimension key -> 0..100 (e.g. { "time": 30, "money": 0 }). A row where
// raterId === rateeId is the person's view of themselves (shown distinctly).
// `submitted` powers blind-then-reveal: drafts don't count until committed.
model StakeRating {
  seedId    String   @map("seed_id") @db.Uuid
  raterId   String   @map("rater_id") @db.Uuid
  rateeId   String   @map("ratee_id") @db.Uuid
  scores    Json     @default("{}")
  submitted Boolean  @default(false)
  // Peer "this person shouldn't decide this" flag. Proportionally discounts the
  // ratee's bloom weight; the removed weight redistributes to the clean quorum.
  crossed   Boolean  @default(false)
  updatedAt DateTime @updatedAt @map("updated_at")

  seed  Seed @relation(fields: [seedId], references: [id], onDelete: Cascade)
  rater User @relation("StakeRater", fields: [raterId], references: [id], onDelete: Cascade)
  ratee User @relation("StakeRatee", fields: [rateeId], references: [id], onDelete: Cascade)

  @@id([seedId, raterId, rateeId])
  @@index([seedId])
  @@map("stake_ratings")
}

// Per-seed stake configuration: which dimensions are live (the rest ruled
// not-applicable by consensus), who has opted out ("not required for me"), and
// the board phase. phase: collecting | revealed | locked.
model SeedStake {
  seedId           String   @id @map("seed_id") @db.Uuid
  activeDimensions Json     @default("[]") @map("active_dimensions")
  optOuts          Json     @default("[]") @map("opt_outs")
  phase            String   @default("collecting")
  // Snapshot of the participant ids at the moment the board was locked. A later
  // contributor not in this set is a "newcomer" who needs an admission vote.
  lockedParticipants Json   @default("[]") @map("locked_participants")
  updatedAt        DateTime @updatedAt @map("updated_at")

  seed Seed @relation(fields: [seedId], references: [id], onDelete: Cascade)

  @@map("seed_stake")
}

// A newcomer's request to join a LOCKED decision quorum. The existing carriers
// vote with their weight; once >50% of the locked stake approves, the board
// reopens so everyone can re-weigh each other and fold the newcomer in.
model StakeAdmission {
  seedId      String   @map("seed_id") @db.Uuid
  candidateId String   @map("candidate_id") @db.Uuid
  status      String   @default("pending") // pending | admitted | declined
  createdAt   DateTime @default(now()) @map("created_at")

  seed  Seed                 @relation(fields: [seedId], references: [id], onDelete: Cascade)
  votes StakeAdmissionVote[]

  @@id([seedId, candidateId])
  @@index([seedId])
  @@map("stake_admissions")
}

model StakeAdmissionVote {
  seedId      String   @map("seed_id") @db.Uuid
  candidateId String   @map("candidate_id") @db.Uuid
  voterId     String   @map("voter_id") @db.Uuid
  approve     Boolean
  votedAt     DateTime @default(now()) @map("voted_at")

  admission StakeAdmission @relation(fields: [seedId, candidateId], references: [seedId, candidateId], onDelete: Cascade)

  @@id([seedId, candidateId, voterId])
  @@map("stake_admission_votes")
}

// ─────────────────────────────────────────────────────────────
// Polls — a question + options inside a seed. weightMode decides whether each
// vote counts equally, or by the voter's stake (the Bloom decision-maker weight).
// ─────────────────────────────────────────────────────────────

model Poll {
  id         String    @id @default(uuid()) @db.Uuid
  seedId     String    @map("seed_id") @db.Uuid
  authorId   String    @map("author_id") @db.Uuid
  question   String
  weightMode String    @default("equal") @map("weight_mode") // equal | stake
  attachments Json     @default("[]") // [{ url, type, name }]
  closedAt   DateTime? @map("closed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  seed    Seed         @relation(fields: [seedId], references: [id], onDelete: Cascade)
  author  User         @relation(fields: [authorId], references: [id])
  options PollOption[]
  votes   PollVote[]

  @@index([seedId])
  @@map("polls")
}

model PollOption {
  id        String @id @default(uuid()) @db.Uuid
  pollId    String @map("poll_id") @db.Uuid
  text      String
  sortOrder Int    @default(0) @map("sort_order")

  poll  Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes PollVote[]

  @@index([pollId])
  @@map("poll_options")
}

model PollVote {
  pollId   String   @map("poll_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  optionId String   @map("option_id") @db.Uuid
  votedAt  DateTime @default(now()) @map("voted_at")

  poll   Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  option PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@id([pollId, userId])
  @@index([optionId])
  @@map("poll_votes")
}

// ─────────────────────────────────────────────────────────────
// Quorum v2 — "emotions → maths". Everyone ranks everyone (themselves
// included) on six fixed dimensions (see lib/constants QUORUM_DIMENSIONS) by
// dragging who most embodies each to the top, up to QUORUM_MAX_RANK. The pure
// engine lives in lib/quorum.ts; these tables just hold the inputs and phase.
// ─────────────────────────────────────────────────────────────

// One rater's ordered ballot for one dimension. `ranking` is a JSON array of
// rateeIds, best first (length ≤ QUORUM_MAX_RANK). `submitted` powers
// blind-then-reveal: drafts don't fold into the result until committed.
model QuorumBallot {
  seedId    String   @map("seed_id") @db.Uuid
  raterId   String   @map("rater_id") @db.Uuid
  dimension String
  ranking   Json     @default("[]")
  submitted Boolean  @default(false)
  updatedAt DateTime @updatedAt @map("updated_at")

  seed  Seed @relation(fields: [seedId], references: [id], onDelete: Cascade)
  rater User @relation("QuorumRater", fields: [raterId], references: [id], onDelete: Cascade)

  @@id([seedId, raterId, dimension])
  @@index([seedId])
  @@map("quorum_ballots")
}

// An admin's hardcode of a measurable dimension (e.g. money) from a ground
// truth. `shares` is a JSON map userId -> positive number (normalised by the
// engine). Attributed to the admin who set it, and shown openly.
model QuorumHardcode {
  seedId    String   @map("seed_id") @db.Uuid
  dimension String
  byId      String   @map("by_id") @db.Uuid
  shares    Json     @default("{}")
  updatedAt DateTime @updatedAt @map("updated_at")

  seed Seed @relation(fields: [seedId], references: [id], onDelete: Cascade)
  by   User @relation("QuorumHardcodedBy", fields: [byId], references: [id], onDelete: Cascade)

  @@id([seedId, dimension])
  @@index([seedId])
  @@map("quorum_hardcodes")
}

// Per-seed quorum phase. collecting (people weigh in privately) → revealed (the
// pies, weights, gaps and tensions are shown) → locked (frozen for the bloom).
model QuorumState {
  seedId       String   @id @map("seed_id") @db.Uuid
  phase        String   @default("collecting") // collecting | revealed | locked
  template     String   @default("decide") // which dimension set: decide | understand
  // "What Claude noticed" — grounded learning-moment observations, generated once
  // at reveal for Understand-together quorums. JSON array of LearningMoment.
  observations Json?    @map("observations")
  updatedAt    DateTime @updatedAt @map("updated_at")

  seed Seed @relation(fields: [seedId], references: [id], onDelete: Cascade)

  @@map("quorum_state")
}

// A durable fixed-window rate-limit counter (no Redis dependency). One row per
// key (e.g. "ai:<userId>"); the window resets when reset_at passes. Updated via
// a single atomic SQL upsert so concurrent serverless instances share the count
// safely. See lib/ratelimit.ts.
model RateLimit {
  key     String   @id
  count   Int      @default(0)
  resetAt DateTime @map("reset_at")

  @@map("rate_limits")
}

// ─────────────────────────────────────────────────────────────
// Contributions
// ─────────────────────────────────────────────────────────────

model Contribution {
  id          String    @id @default(uuid()) @db.Uuid
  seedId      String    @map("seed_id") @db.Uuid
  parentId    String?   @map("parent_id") @db.Uuid
  authorId    String    @map("author_id") @db.Uuid
  dimension   String // foundations | understanding | application | debate | bloom
  contentType String    @default("text") @map("content_type") // text | image | video | link | code | quote
  content     Json // { text, formatting?, attachments? }
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  seed     Seed           @relation(fields: [seedId], references: [id], onDelete: Cascade)
  author   User           @relation(fields: [authorId], references: [id])
  parent   Contribution?  @relation("Replies", fields: [parentId], references: [id])
  replies  Contribution[] @relation("Replies")
  reactions    ContributionReaction[]
  endorsements ContributionEndorsement[]

  @@index([seedId, dimension])
  @@index([parentId])
  // Distinct-author lookups (participant lists, quorum roster) filter by seed
  // and group by author — this keeps that off a per-seed contribution scan.
  @@index([seedId, authorId])
  @@map("contributions")
}

model ReactionType {
  key       String  @id
  emoji     String
  label     String
  module    String  @default("learning")
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  reactions ContributionReaction[]

  @@map("reaction_types")
}

model ContributionReaction {
  contributionId String   @map("contribution_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  reactionKey    String   @map("reaction_key")
  reactedAt      DateTime @default(now()) @map("reacted_at")

  contribution Contribution @relation(fields: [contributionId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  reaction     ReactionType @relation(fields: [reactionKey], references: [key])

  @@id([contributionId, userId, reactionKey])
  @@map("contribution_reactions")
}

model ContributionEndorsement {
  contributionId String   @map("contribution_id") @db.Uuid
  endorserId     String   @map("endorser_id") @db.Uuid
  endorsedAt     DateTime @default(now()) @map("endorsed_at")

  contribution Contribution @relation(fields: [contributionId], references: [id], onDelete: Cascade)
  endorser     User         @relation(fields: [endorserId], references: [id], onDelete: Cascade)

  @@id([contributionId, endorserId])
  @@map("contribution_endorsements")
}

// ─────────────────────────────────────────────────────────────
// Blooms
// ─────────────────────────────────────────────────────────────

model Bloom {
  id            String   @id @default(uuid()) @db.Uuid
  gardenId      String   @map("garden_id") @db.Uuid
  seedId        String   @map("seed_id") @db.Uuid
  version       Int      @default(1)
  title         String
  summary       String
  content       Json
  aiSynthesized Boolean  @default(false) @map("ai_synthesized")
  bloomedAt     DateTime @default(now()) @map("bloomed_at")
  createdById   String?  @map("created_by") @db.Uuid // who cast the tipping vote

  garden       Garden            @relation(fields: [gardenId], references: [id], onDelete: Cascade)
  seed         Seed              @relation(fields: [seedId], references: [id], onDelete: Cascade)
  createdBy    User?             @relation("BloomCreatedBy", fields: [createdById], references: [id])
  contributors BloomContributor[]

  @@unique([seedId, version])
  @@index([gardenId, bloomedAt])
  @@map("blooms")
}

model BloomContributor {
  id               String   @id @default(uuid()) @db.Uuid
  bloomId          String   @map("bloom_id") @db.Uuid
  userId           String?  @map("user_id") @db.Uuid
  email            String?
  name             String?
  role             String
  contributionType String?  @map("contribution_type") // seed_planter | explainer | practitioner | debater | mentor | community
  sortOrder        Int      @default(0) @map("sort_order")
  addedById        String?  @map("added_by") @db.Uuid
  addedAt          DateTime @default(now()) @map("added_at")

  bloom Bloom @relation(fields: [bloomId], references: [id], onDelete: Cascade)

  @@unique([bloomId, userId])
  @@map("bloom_contributors")
}

// ─────────────────────────────────────────────────────────────
// Recognition
// ─────────────────────────────────────────────────────────────

model RecognitionLabel {
  key         String  @id
  emoji       String?
  label       String?
  description String?
  sortOrder   Int     @default(0) @map("sort_order")

  awards UserRecognition[]

  @@map("recognition_labels")
}

model UserRecognition {
  userId    String   @map("user_id") @db.Uuid
  labelKey  String   @map("label_key")
  gardenId  String   @map("garden_id") @db.Uuid
  awardedById String @map("awarded_by") @db.Uuid
  awardedAt DateTime @default(now()) @map("awarded_at")

  user    User             @relation("RecognitionUser", fields: [userId], references: [id], onDelete: Cascade)
  label   RecognitionLabel @relation(fields: [labelKey], references: [key])
  garden  Garden           @relation(fields: [gardenId], references: [id], onDelete: Cascade)
  awardedBy User           @relation("RecognitionAwardedBy", fields: [awardedById], references: [id])

  @@id([userId, labelKey, gardenId, awardedById])
  @@map("user_recognition")
}

// ─────────────────────────────────────────────────────────────
// Notifications
// ─────────────────────────────────────────────────────────────

model Notification {
  id          String    @id @default(uuid()) @db.Uuid
  recipientId String    @map("recipient_id") @db.Uuid
  type        String // stage_change | bloom | contribution | member_joined | endorsement | mention
  title       String
  body        String?
  entityType  String?   @map("entity_type") // seed | bloom | garden | contribution
  entityId    String?   @map("entity_id") @db.Uuid
  anchorId    String?   @map("anchor_id") @db.Uuid // the exact contribution to scroll to
  actorId     String?   @map("actor_id") @db.Uuid
  readAt      DateTime? @map("read_at")
  // When this notification was delivered over each external channel, so the
  // daily digest never re-sends what already went out instantly.
  emailedAt   DateTime? @map("emailed_at")
  pushedAt    DateTime? @map("pushed_at")
  // When this notification was rolled into a twice-daily re-engagement push, so
  // the morning and evening nudge slots never re-summarise the same item.
  nudgedAt    DateTime? @map("nudged_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  recipient User  @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor     User? @relation("NotificationActor", fields: [actorId], references: [id])

  @@index([recipientId, createdAt])
  // Support the cron fan-outs: the digest scans un-emailed rows by recency, the
  // nudge scans un-read/un-nudged rows by recency. Without these, both crons
  // table-scan as notification volume grows.
  @@index([emailedAt, createdAt])
  @@index([readAt, nudgedAt, createdAt])
  @@map("notifications")
}

// A browser/device push subscription (Web Push). One person can have several —
// phone, laptop — so we keep them per-endpoint and prune dead ones on send.
model PushSubscription {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?  @map("user_agent") // device label, for multi-device diagnostics
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

// ─────────────────────────────────────────────────────────────
// Invites — shareable join links, optionally scoped to an email.
// Accepting joins the org (and the garden, if scoped to one).
// ─────────────────────────────────────────────────────────────

model Invite {
  id           String    @id @default(uuid()) @db.Uuid
  orgId        String    @map("org_id") @db.Uuid
  gardenId     String?   @map("garden_id") @db.Uuid
  seedId       String?   @map("seed_id") @db.Uuid // scope to a private seed
  email        String? // optional: restrict who can accept
  role         String    @default("member")
  token        String    @unique
  invitedById  String    @map("invited_by") @db.Uuid
  status       String    @default("pending") // pending | accepted | revoked
  expiresAt    DateTime  @map("expires_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  acceptedAt   DateTime? @map("accepted_at")
  acceptedById String?   @map("accepted_by") @db.Uuid

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  garden    Garden?      @relation(fields: [gardenId], references: [id], onDelete: Cascade)
  seed      Seed?        @relation(fields: [seedId], references: [id], onDelete: Cascade)
  invitedBy User         @relation("InvitesSent", fields: [invitedById], references: [id])

  @@index([orgId])
  @@map("invites")
}

// The daily "good morning" message library — editable by the owner from the
// admin screen (a calm yearly curation). When this table has active rows they
// drive the daily message; otherwise the app falls back to the built-in set in
// lib/daily-messages.ts, so nothing ever breaks.
model DailyQuote {
  id        String   @id @default(uuid()) @db.Uuid
  text      String
  author    String?
  action    String? // a short "do this today" nudge Claude crafts from the quote
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([active])
  @@map("daily_quotes")
}

// One row per @claude / @chatgpt tag — a silent usage meter for stats now and
// for enforcing a free monthly quota later. No relation field (userId is a
// plain column) so it needs no change to the User model.
model AiTagEvent {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  provider  String // claude | chatgpt
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("ai_tag_events")
}

// Free-form topics shown on a person's profile — Claude reads the seeds they're
// involved in and groups their areas into concise tags (not limited to the 14
// Explore buckets). `manual` marks topics the person added themselves, which a
// refresh keeps; auto ones are regenerated.
model UserTopic {
  userId    String   @map("user_id") @db.Uuid
  topic     String
  manual    Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@id([userId, topic])
  @@index([userId])
  @@map("user_topics")
}

// A short, honest "how you show up in conversations" reflection Claude writes by
// reading a person's own contributions — a mirror of what they actually bring to
// the table. One per user; regenerated from their latest activity.
model UserReflection {
  userId    String   @id @map("user_id") @db.Uuid
  summary   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_reflections")
}

// One person following another (one-directional, no approval — like following a
// thinker whose public work you want to hear about). Powers "someone you follow
// did something public" notifications and follower/following counts. No DMs,
// ever — ThinkThru is thinking in the open, not private messaging.
model UserFollow {
  followerId  String   @map("follower_id") @db.Uuid
  followingId String   @map("following_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  @@id([followerId, followingId])
  @@index([followingId])
  @@map("user_follows")
}

// Per-section privacy on a person's profile: whether a given section (reflection,
// topics, involved seeds, ai tags…) is visible to others. A missing row means
// "use the section's default" (see SECTION_PUBLIC_DEFAULT in services/profile).
model UserSectionVisibility {
  userId  String  @map("user_id") @db.Uuid
  section String
  public  Boolean @default(true)

  @@id([userId, section])
  @@map("user_section_visibility")
}

// A heartbeat row per cron slot (morning / evening / digest) so we can confirm
// the scheduler actually fired — surfaced in /admin. Distinguishes a firing-but-
// empty cron from one that never runs (e.g. a missing CRON_SECRET self-401).
model CronRun {
  name      String   @id
  lastRunAt DateTime @default(now()) @map("last_run_at")
  detail    String?

  @@map("cron_runs")
}

// One person's answer to the daily question — the tiny, tap-to-answer ritual
// meant to bring people back every day. `day` is the UTC "YYYY-MM-DD" the
// question belongs to; `choice` is the index into that day's options. One answer
// per person per day (changeable). The question text lives in code
// (daily-questions.ts), so we only store the choice.
model DailyAnswer {
  day       String
  userId    String   @map("user_id") @db.Uuid
  choice    Int
  createdAt DateTime @default(now()) @map("created_at")

  @@id([day, userId])
  @@index([day])
  @@map("daily_answers")
}
