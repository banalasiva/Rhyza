# ─────────────────────────────────────────────────────────────
# ThinkThru — environment variables
# Copy to `.env` for local dev. In production set these in Vercel.
# ─────────────────────────────────────────────────────────────

# Postgres (Neon). Use the POOLED connection string for the app at runtime,
# and the DIRECT (non-pooled) string for migrations.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Auth.js (NextAuth v5)
# Generate a secret: `openssl rand -base64 32`
AUTH_SECRET="replace-me-with-a-long-random-string"
# Base URL of the app (only needed if not auto-detected, e.g. behind a proxy)
# AUTH_URL="https://your-app.vercel.app"

# ── Google OAuth (personal sign-in) ──
# Create at https://console.cloud.google.com/apis/credentials
#  Authorized redirect URI: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ── Enterprise SSO (OIDC) — optional ──
# Works with Okta, Azure AD / Entra ID, Google Workspace, Auth0, etc.
# Leave blank to disable the "Sign in with SSO" button.
#  Authorized redirect URI: {AUTH_URL}/api/auth/callback/sso
AUTH_SSO_ISSUER=""          # e.g. https://your-org.okta.com
AUTH_SSO_CLIENT_ID=""
AUTH_SSO_CLIENT_SECRET=""
AUTH_SSO_NAME="SSO"         # button label, e.g. "Okta" or "Microsoft"

# ── Enterprise SSO (SAML) — optional, via SAML Jackson ──
# Only needed for IdPs that speak SAML but not OIDC. See DEPLOY.md.
# SAML_JACKSON_URL=""
# SAML_JACKSON_CLIENT_ID=""
# SAML_JACKSON_CLIENT_SECRET=""

# ── Invites / email (Resend) — optional ──
# Public base URL used to build invite links (e.g. https://your-app.vercel.app).
# Defaults to AUTH_URL, then http://localhost:3000.
APP_URL="http://localhost:3000"
# Resend API key from https://resend.com/api-keys. If unset, invite LINKS still
# work (shown in the UI to copy) but no emails are sent.
RESEND_API_KEY=""
# Verified sender. For quick testing you can use Resend's shared sender below;
# for production, verify your own domain and use e.g. "ThinkThru <invites@yourdomain.com>".
RESEND_FROM="ThinkThru <onboarding@resend.dev>"

# ── Claude AI (Anthropic) — optional but recommended ──
# Powers AI bloom synthesis and the @claude participant in conversations.
# Get a key at https://console.anthropic.com/settings/keys
# If unset, blooms fall back to a deterministic summary and @claude mentions
# simply go unanswered — the app still works.
ANTHROPIC_API_KEY=""

# ── File uploads (Vercel Blob) — optional ──
# Enables attaching images, videos, and screenshots to contributions. In Vercel:
# Storage → create a Blob store → it sets this automatically on the project.
# For local dev, copy the token from the store's settings. If unset, the
# "📎 Attach" button is simply hidden.
BLOB_READ_WRITE_TOKEN=""
